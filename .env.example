# Safety Net Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string (TimescaleDB recommended for health_factor_history)
DATABASE_URL=postgres://localhost/safetynet

# Redis for sessions, pub/sub, and caching
REDIS_URL=redis://localhost:6379

# =============================================================================
# ETHEREUM
# =============================================================================
# WebSocket RPC for block subscriptions (e.g., Alchemy, Infura)
ETH_RPC_WS=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# HTTP RPC for one-off calls
ETH_RPC_HTTP=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# =============================================================================
# TRANSACTION SIMULATION
# =============================================================================
# Tenderly credentials for transaction simulation
TENDERLY_API_KEY=
TENDERLY_PROJECT=safetynet
TENDERLY_USER=

# =============================================================================
# PRIVATE MEMPOOL (for Autopilot tier)
# =============================================================================
# Flashbots RPC endpoint
FLASHBOTS_RPC=https://relay.flashbots.net

# Private key for signing bundles (keep secure!)
FLASHBOTS_SIGNER_KEY=

# =============================================================================
# NOTIFICATIONS
# =============================================================================
# Firebase Cloud Messaging for push notifications
FCM_API_KEY=

# Telegram bot for alerts
TELEGRAM_BOT_TOKEN=

# SendGrid for email alerts
SENDGRID_API_KEY=

# =============================================================================
# BILLING (x402 micropayments)
# =============================================================================
# x402 streaming payments contract address
X402_CONTRACT_ADDRESS=

# Wallet to receive fees
FEE_WALLET_ADDRESS=

# =============================================================================
# GUARDIAN SIGNER (for Autopilot mode)
# =============================================================================
# Private key for the guardian signer
# In production, use AWS KMS or similar secure key storage
GUARDIAN_SIGNER_KEY=

# =============================================================================
# SERVER
# =============================================================================
# Port to listen on (default: 3460)
PORT=3460
